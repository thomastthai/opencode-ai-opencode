{
  "$schema": "./opencode-schema.json",
  "lsp": {
    "gopls": {
      "command": "gopls"
    }
  },
  "tui": {
    "showModelInfo": false,
    "messageLayout": "messaging",
    "messageLayoutConfig": {
      "userMessageWidth": 0.65,
      "assistantMessageWidth": 0.75,
      "userRightMargin": 10,
      "assistantLeftMargin": 2,
      "useBackgrounds": true,
      "useRoundedBorders": true,
      "userTextColor": "#ffffff",
      "userBackgroundColor": "#2563eb",
      "assistantTextColor": "#374151",
      "assistantBackgroundColor": "#f3f4f6",
      "userBorder": {
        "character": "│",
        "horizontalChar": "─",
        "topLeftChar": "┌",
        "topRightChar": "┐",
        "bottomLeftChar": "└",
        "bottomRightChar": "┘",
        "foregroundColor": "#1d4ed8",
        "backgroundColor": "",
        "sides": {
          "top": true,
          "right": true,
          "bottom": true,
          "left": true
        }
      },
      "assistantBorder": {
        "character": "│",
        "horizontalChar": "─",
        "topLeftChar": "┌",
        "topRightChar": "┐",
        "bottomLeftChar": "└",
        "bottomRightChar": "┘",
        "foregroundColor": "#6b7280",
        "backgroundColor": "",
        "sides": {
          "top": true,
          "right": true,
          "bottom": true,
          "left": true
        }
      }
    }
  }
}
